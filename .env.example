HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
JWT_SECRET=change-me-jwt-secret
ENCRYPTION_KEY=change-me-encryption-key
SPORT_API_URL=http://localhost:4000
SPORT_WEBHOOK_SECRET=

# --- Database (локально по умолчанию SQLite) ---
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# --- PostgreSQL (Railway / production) ---
# В Railway на сервисе Strapi:
#   DATABASE_CLIENT=postgres
#   DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
# Не используйте публичный URL внутри Railway — только PRIVATE.
#
# SSL обычно не нужен для internal URL; для публичного TCP proxy:
#   DATABASE_SSL=true
DATABASE_CLIENT=
DATABASE_URL=

# Опционально (переопределение авто-настроек пула)
# DATABASE_POOL_MIN=0
# DATABASE_POOL_MAX=5
# DATABASE_SSL=false
