HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
JWT_SECRET=change-me-jwt-secret
ENCRYPTION_KEY=change-me-encryption-key
SPORT_API_URL=http://localhost:4000
SPORT_WEBHOOK_SECRET=

# --- Railway: PostgreSQL (рекомендуется) ---
# Strapi → Variables → Add Reference → Postgres → DATABASE_PRIVATE_URL
# DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
#
# Или отдельные поля (имя сервиса Postgres может отличаться):
# PGHOST=${{Postgres.PGHOST}}
# PGPORT=${{Postgres.PGPORT}}
# PGUSER=${{Postgres.PGUSER}}
# PGPASSWORD=${{Postgres.PGPASSWORD}}
# PGDATABASE=${{Postgres.PGDATABASE}}
#
# DATABASE_CLIENT задавать не обязательно — определяется автоматически.
# Если Postgres не подключён, Strapi стартует на SQLite (данные не сохранятся между redeploy).

# --- Локально (SQLite) ---
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
